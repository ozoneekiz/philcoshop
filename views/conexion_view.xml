<odoo>
    <!-- Vista formulario de configuración -->
    <record id="view_philcoshop_settings_form" model="ir.ui.view">
        <field name="name">philco.conexion.form</field>
        <field name="model">philco.conexion</field>
        <field name="arch" type="xml">
            <form string="Configuración de la coneccion con philco shop">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url_base"/>
                        
                        <field name="api_endpoint"/>
                        <field name="whatsapp_number"/>
                        <field name="access_token" password="True"/>
                        <field name="active"/>
                        <field name="days_to_expire" widget="integer"/>
                        <field name="url_shared" widget="url" readonly="True"/> <!-- Campo para mostrar la URL para compartir -->
                        <field name="expire_date"  readonly="True"/> <!-- Campo para mostrar la fecha de expiración -->
                    </group>
                    <group name="conexion_status" string="Estado de la Conexión">
                        <button name="verificar_conexion" string="Verificar Conexión" type="object" class="oe_highlight"/>
                        <button name="actualizar_whatsapp_number" string="Actualizar Número de WhatsApp" type="object" class="oe_highlight"/>
                        <button name="crear_empresa" string="Crear Empresa en Philco Shop" type="object" class="oe_highlight"/>
                        
                        <button name="get_url_shared" string="Obtener URL para Compartir" type="object" class="oe_highlight" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista tipo lista (opcional, para ver varias configuraciones) -->
    <record id="view_philcoshop_settings_tree" model="ir.ui.view">
        <field name="name">philco.conexion.tree</field>
        <field name="model">philco.conexion</field>
        <field name="arch" type="xml">
            <list string="Configuraciones de la coneccion con philco shop">
                 <!-- <header>
                     <button name="importar_categorias_magento" string="Mi Botón" type="object" class="oe_highlight"/>
                 </header> -->
                <field name="name"/>
                <field name="url_base"/>
                <field name="api_endpoint"/>
                <field name="whatsapp_number"/>
                <field name="active"/>
                
            </list>
        </field>
    </record>

    <!-- Acción para abrir la configuración -->
    <record id="action_philco_settings" model="ir.actions.act_window">
        <field name="name">Configuración de Philco Shop</field>
        <field name="res_model">philco.conexion</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Aquí puedes definir la conexión con tu tienda philco shop.</p>
        </field>
    </record>

   
</odoo>
