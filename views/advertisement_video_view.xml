<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         VISTA LISTA
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_advertisement_video_list" model="ir.ui.view">
        <field name="name">advertisement.video.list</field>
        <field name="model">advertisement.video</field>
        <field name="arch" type="xml">
            <list string="Videos Publicitarios"
                  decoration-muted="not is_active"
                  decoration-success="status == 'active'"
                  decoration-warning="status == 'scheduled'"
                  decoration-danger="status == 'expired'">

                <!-- Botón de refresco en la cabecera -->
                <header>
                    <button name="action_refresh"
                            string="↻ Sincronizar con API"
                            type="object"
                            class="btn-secondary"/>
                </header>

                <field name="sort_order" string="Orden" width="60"/>
                <field name="name" string="Nombre"/>
                <field name="video_url" string="URL del Video" optional="show"/>
                <field name="button_text" string="Botón" optional="show"/>
                <field name="is_active" string="Activo" widget="boolean_toggle"/>
                <field name="starts_at" string="Inicio" optional="show"/>
                <field name="ends_at" string="Fin" optional="show"/>
                <field name="status" string="Estado" widget="badge"
                       decoration-success="status == 'active' or status == 'always'"
                       decoration-warning="status == 'scheduled'"
                       decoration-danger="status == 'expired'"/>
                <field name="external_id" string="ID API" optional="hide"/>

                <!-- Acciones rápidas por fila -->
                <button name="action_toggle_active"
                        type="object"
                        icon="fa-power-off"
                        title="Activar / Desactivar"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         VISTA FORMULARIO
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_advertisement_video_form" model="ir.ui.view">
        <field name="name">advertisement.video.form</field>
        <field name="model">advertisement.video</field>
        <field name="arch" type="xml">
            <form string="Video Publicitario">

                <!-- Barra de estado visual -->
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="scheduled,active,expired,always"/>
                </header>

                <sheet>
                    <!-- Badge de ID externo + toggle activo -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_toggle_active"
                                icon="fa-video-camera">
                            <field name="is_active" widget="boolean_button"
                                   options='{"terminology": {"string_true": "Activo", "string_false": "Inactivo", "hover_true": "Desactivar", "hover_false": "Activar"}}'/>
                        </button>
                    </div>

                    <!-- ID externo visible como referencia -->
                    <div class="oe_title">
                        <label for="name" string="Nombre del Video"/>
                        <h1>
                            <field name="name" placeholder="Ej: Promo Verano 2025"/>
                        </h1>
                        <field name="external_id" readonly="1"
                               invisible="external_id == 0"
                               string="API ID"/>
                    </div>

                    <group>
                        <!-- Columna izquierda -->
                        <group string="Contenido del Video">
                            <field name="video_url"
                                   placeholder="https://ejemplo.com/video.mp4"
                                   widget="url"/>
                            <field name="description"
                                   placeholder="Descripción opcional del video..."/>
                        </group>

                        <!-- Columna derecha -->
                        <group string="Call to Action (Botón)">
                            <field name="button_text"
                                   placeholder="Ej: Ver más, Comprar ahora..."/>
                            <field name="button_url"
                                   placeholder="https://..."
                                   widget="url"/>
                        </group>
                    </group>

                    <group string="Configuración de Publicación">
                        <group>
                            <field name="sort_order"
                                   help="Menor número = mayor prioridad en la lista"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="starts_at"
                                   help="Dejar vacío para que aparezca siempre"/>
                            <field name="ends_at"
                                   help="Dejar vacío para que no expire"/>
                        </group>
                    </group>

                    <!-- Preview del video si tiene URL -->
                    <group string="Vista previa" invisible="not video_url">
                        <field name="video_url"
                               string="Enlace directo"
                               widget="url"
                               readonly="1"/>
                    </group>

                </sheet>

                <!-- Chatter deshabilitado (no es un modelo real de Odoo) -->

            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         VISTA BÚSQUEDA / FILTROS
    ══════════════════════════════════════════════════════════════ -->
    <record id="view_advertisement_video_search" model="ir.ui.view">
        <field name="name">advertisement.video.search</field>
        <field name="model">advertisement.video</field>
        <field name="arch" type="xml">
            <search string="Buscar Videos">
                <field name="name" string="Nombre"/>
                <field name="description" string="Descripción"/>

                <separator/>

                <filter string="Activos" name="active"
                        domain="[('is_active', '=', True)]"/>
                <filter string="Inactivos" name="inactive"
                        domain="[('is_active', '=', False)]"/>

                <separator/>

                <filter string="Con botón CTA" name="with_button"
                        domain="[('button_url', '!=', False)]"/>
                <filter string="Sin fechas (siempre visible)" name="always"
                        domain="[('starts_at', '=', False), ('ends_at', '=', False)]"/>

                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Activo" name="group_active"
                            context="{'group_by': 'is_active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         ACCIÓN DE VENTANA
    ══════════════════════════════════════════════════════════════ -->
    <record id="action_advertisement_video" model="ir.actions.act_window">
        <field name="name">Videos Publicitarios</field>
        <field name="res_model">advertisement.video</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_advertisement_video_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡No hay videos publicitarios todavía!
            </p>
            <p>
                Crea el primer video o sincroniza con la API externa.
            </p>
        </field>
    </record>

</odoo>